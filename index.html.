<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CBM Website Design Intake Form</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #f0f2f5;
    color: #1a202c;
    font-size: 13px;
    padding: 30px 20px;
  }
  .page {
    max-width: 860px;
    margin: 0 auto;
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
  }

  /* HEADER */
  .header {
    background: #1A1A2E;
    padding: 22px 30px;
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .header img {
    width: 62px;
    height: 62px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .header-text h1 {
    font-size: 22px;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.5px;
    line-height: 1.1;
  }
  .header-text h1 span { color: #F6973F; }
  .header-text p {
    color: #9AA5B4;
    font-size: 11px;
    margin-top: 4px;
    letter-spacing: 0.3px;
  }

  /* INTRO */
  .intro {
    background: #F7FAFC;
    border-left: 4px solid #F6973F;
    padding: 12px 20px;
    margin: 22px 28px 10px;
    border-radius: 0 6px 6px 0;
    color: #4A5568;
    font-size: 12px;
    line-height: 1.6;
    font-style: italic;
  }

  /* BODY */
  .form-body {
    padding: 6px 28px 28px;
  }

  /* SECTION HEADER */
  .section-header {
    background: #2D3748;
    border-radius: 6px;
    padding: 10px 16px 10px 14px;
    margin: 24px 0 14px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .section-badge {
    background: #F6973F;
    color: #fff;
    font-weight: 800;
    font-size: 11px;
    width: 24px;
    height: 24px;
    border-radius: 5px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .section-header h2 {
    color: #fff;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ROWS */
  .row {
    display: flex;
    gap: 14px;
    margin-bottom: 13px;
  }
  .row .field-group { flex: 1; }
  .field-group { margin-bottom: 13px; }

  /* LABELS */
  .field-group label {
    display: block;
    font-weight: 700;
    font-size: 11.5px;
    color: #2D3748;
    margin-bottom: 5px;
  }
  .field-group label span.hint {
    font-weight: 400;
    color: #718096;
    font-style: italic;
    font-size: 10.5px;
  }

  /* INPUTS */
  input[type="text"],
  textarea {
    width: 100%;
    background: #F4F6F9;
    border: 1px solid #C8D0DC;
    border-radius: 5px;
    padding: 8px 10px;
    font-size: 12px;
    color: #1a202c;
    font-family: inherit;
    transition: border 0.2s, box-shadow 0.2s;
    resize: vertical;
  }
  input[type="text"]:focus,
  textarea:focus {
    outline: none;
    border-color: #2B6CB0;
    box-shadow: 0 0 0 3px rgba(43,108,176,0.12);
    background: #fff;
  }
  input[type="text"]::placeholder,
  textarea::placeholder {
    color: #A0AEC0;
    font-style: italic;
    font-size: 11px;
  }
  textarea.sm { height: 62px; }
  textarea.md { height: 84px; }
  textarea.lg { height: 110px; }

  /* CHECKBOXES */
  .checkbox-section { margin-bottom: 14px; }
  .checkbox-section .cb-question {
    font-weight: 700;
    font-size: 11.5px;
    color: #2D3748;
    margin-bottom: 8px;
  }
  .cb-grid {
    display: grid;
    gap: 7px 0;
  }
  .cb-grid.cols-2 { grid-template-columns: 1fr 1fr; }
  .cb-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
  .cb-grid.cols-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
  .cb-item {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }
  .cb-item input[type="checkbox"] {
    width: 15px;
    height: 15px;
    accent-color: #F6973F;
    cursor: pointer;
    flex-shrink: 0;
    margin: 0;
  }
  .cb-item span {
    font-size: 12px;
    color: #2D3748;
  }

  /* INFO BANNER */
  .info-banner {
    background: #EBF4FF;
    border: 1.5px solid #2B6CB0;
    border-radius: 6px;
    padding: 10px 14px;
    margin-bottom: 14px;
    font-size: 11.5px;
    color: #2B6CB0;
    font-weight: 600;
    line-height: 1.5;
  }

  /* LOGO BANNER */
  .logo-banner {
    background: #EBF4FF;
    border: 1.5px solid #2B6CB0;
    border-radius: 6px;
    padding: 11px 16px;
    margin: 6px 0 14px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
  }
  .logo-banner .lb-icon {
    font-size: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .logo-banner .lb-text {
    font-size: 11.5px;
    color: #2B6CB0;
    font-weight: 600;
    line-height: 1.6;
  }
  .logo-banner .lb-text span {
    font-weight: 400;
    color: #4A5568;
    display: block;
    font-size: 11px;
    margin-top: 2px;
  }

  /* COMPETITOR BLOCK */
  .competitor-block {
    background: #F7FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 7px;
    padding: 13px 14px;
    margin-bottom: 12px;
  }
  .competitor-block .comp-title {
    font-weight: 700;
    font-size: 11.5px;
    color: #2D3748;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #E2E8F0;
  }

  /* INSPIRATION BLOCK */
  .inspiration-block {
    background: #F7FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 7px;
    padding: 13px 14px;
    margin-bottom: 12px;
  }
  .inspiration-block .insp-title {
    font-weight: 700;
    font-size: 11.5px;
    color: #2D3748;
    margin-bottom: 10px;
    padding-bottom: 6px;
    border-bottom: 1px solid #E2E8F0;
  }

  /* FOOTER */
  .footer {
    background: #1A1A2E;
    padding: 13px 28px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
  }
  .footer p {
    color: #fff;
    font-size: 11px;
    font-weight: 600;
  }
  .footer span {
    color: #9AA5B4;
    font-size: 11px;
  }

  /* CLOSING PANEL */
  .closing {
    background: #2D3748;
    border-radius: 8px;
    padding: 16px 20px;
    margin-top: 22px;
  }
  .closing h3 {
    color: #F6973F;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.5px;
    margin-bottom: 5px;
    text-transform: uppercase;
  }
  .closing p {
    color: #fff;
    font-size: 12px;
    margin-bottom: 3px;
  }
  .closing small {
    color: #9AA5B4;
    font-size: 11px;
    font-style: italic;
  }

  /* PRINT */
  @media print {
    body { background: #fff; padding: 0; }
    .page { box-shadow: none; border-radius: 0; max-width: 100%; }
    input[type="text"], textarea {
      border: 1px solid #C8D0DC !important;
      background: #F4F6F9 !important;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
  }
</style>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="header">
    <img src="data:image/png;base64," alt="Circuit Bloom Media Logo">
    <div class="header-text">
      <h1>WEBSITE DESIGN <span>INTAKE FORM</span></h1>
      <p>Circuit Bloom Media &nbsp;|&nbsp; Confidential Client Brief</p>
    </div>
  </div>

  <!-- INTRO -->
  <p class="intro">
    Please complete every section as thoroughly as possible. Your responses guide our entire design, structure, and strategy.
    The more detail you provide, the better we can build something that truly represents your brand and converts visitors into clients.
    When complete, email this form along with your logo files to <strong>info@cbmedia.ae</strong>.
  </p>

  <div class="form-body">

    <!-- SECTION 1: CONTACT -->
    <div class="section-header">
      <div class="section-badge">1</div>
      <h2>Your Contact Information</h2>
    </div>

    <div class="row">
      <div class="field-group">
        <label>First Name</label>
        <input type="text" placeholder="e.g. Sarah">
      </div>
      <div class="field-group">
        <label>Last Name</label>
        <input type="text" placeholder="e.g. Johnson">
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Your Email Address</label>
        <input type="text" placeholder="e.g. sarah@yourbusiness.com">
      </div>
      <div class="field-group">
        <label>Your Phone Number <span class="hint">(include country code)</span></label>
        <input type="text" placeholder="e.g. +971 50 123 4567">
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Your Job Title or Role</label>
        <input type="text" placeholder="e.g. Owner, CEO, Marketing Manager">
      </div>
      <div class="field-group">
        <label>City and Country</label>
        <input type="text" placeholder="e.g. Dubai, UAE">
      </div>
    </div>

    <!-- SECTION 2: BUSINESS INFO -->
    <div class="section-header">
      <div class="section-badge">2</div>
      <h2>Business Information</h2>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Business / Company Name</label>
        <input type="text" placeholder="e.g. Spark Creative Studio">
      </div>
      <div class="field-group">
        <label>Tagline or Slogan <span class="hint">(if you have one)</span></label>
        <input type="text" placeholder="e.g. Building brands that convert.">
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Industry or Sector</label>
        <input type="text" placeholder="e.g. Real Estate, Fashion, Health and Wellness, Tech">
      </div>
      <div class="field-group">
        <label>Years in Business</label>
        <input type="text" placeholder="e.g. 3 years, or just launched">
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Existing Website URL <span class="hint">(if any)</span></label>
        <input type="text" placeholder="e.g. www.yourbusiness.com or leave blank">
      </div>
      <div class="field-group">
        <label>Main Social Media Handles</label>
        <input type="text" placeholder="e.g. @yourbrand on Instagram, LinkedIn URL">
      </div>
    </div>

    <div class="field-group">
      <label>What does your business do? <span class="hint">Describe your products or services clearly.</span></label>
      <textarea class="md" placeholder="e.g. We provide luxury property management services for short-term rental owners in Dubai, handling everything from guest communication to cleaning and maintenance. Our clients earn passive income without managing anything themselves."></textarea>
    </div>

    <div class="field-group">
      <label>Who is your target audience? <span class="hint">Think: age, location, income, profession, lifestyle.</span></label>
      <textarea class="md" placeholder="e.g. High-income professionals aged 30 to 55 in the UAE looking to invest in real estate without the stress of day-to-day management. Mostly referred clients and social media leads."></textarea>
    </div>

    <div class="field-group">
      <label>What problem does your business solve for clients?</label>
      <textarea class="sm" placeholder="e.g. We remove the complexity of managing rental properties so owners earn consistent passive income without lifting a finger."></textarea>
    </div>

    <div class="logo-banner">
      <div class="lb-icon">📎</div>
      <div class="lb-text">
        LOGO FILE: Please attach your logo when submitting this form.
        <span>Accepted formats: PNG, SVG, AI, or EPS. Transparent background preferred. If you have multiple versions (dark, light, icon only), please include them all.</span>
      </div>
    </div>

    <!-- SECTION 3: WEBSITE GOALS -->
    <div class="section-header">
      <div class="section-badge">3</div>
      <h2>Website Goals</h2>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">What is the primary goal of this website? <span style="font-weight:400;color:#718096;">(Select all that apply)</span></div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Generate leads</span></label>
        <label class="cb-item"><input type="checkbox"><span>Sell products online</span></label>
        <label class="cb-item"><input type="checkbox"><span>Book appointments</span></label>
        <label class="cb-item"><input type="checkbox"><span>Showcase services or portfolio</span></label>
        <label class="cb-item"><input type="checkbox"><span>Build brand credibility</span></label>
        <label class="cb-item"><input type="checkbox"><span>Provide information</span></label>
        <label class="cb-item"><input type="checkbox"><span>Drive event sign-ups</span></label>
        <label class="cb-item"><input type="checkbox"><span>Build a members area</span></label>
        <label class="cb-item"><input type="checkbox"><span>Other (describe below)</span></label>
      </div>
    </div>

    <div class="field-group">
      <label>What specific actions do you want visitors to take on the site?</label>
      <textarea class="sm" placeholder="e.g. Click Request a Consultation, enter their email to join a waitlist, call our office directly, or purchase a product."></textarea>
    </div>

    <div class="field-group">
      <label>What does success look like 90 days after your website launches?</label>
      <textarea class="sm" placeholder="e.g. 50 qualified leads per month, 200 daily visitors, 10 product sales per week, or top 3 Google ranking for our main service keyword."></textarea>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Ideal Launch Date or Deadline</label>
        <input type="text" placeholder="e.g. Within 3 weeks, by July 1st">
      </div>
      <div class="field-group">
        <label>Estimated Budget for this Project</label>
        <input type="text" placeholder="e.g. AED 8,000 to 15,000  or  USD 3,000+">
      </div>
    </div>

    <!-- SECTION 4: PAGES -->
    <div class="section-header">
      <div class="section-badge">4</div>
      <h2>Pages and Structure</h2>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">Which pages do you need on your website? <span style="font-weight:400;color:#718096;">(Select all that apply)</span></div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Home</span></label>
        <label class="cb-item"><input type="checkbox"><span>About</span></label>
        <label class="cb-item"><input type="checkbox"><span>Services</span></label>
        <label class="cb-item"><input type="checkbox"><span>Contact</span></label>
        <label class="cb-item"><input type="checkbox"><span>FAQ</span></label>
        <label class="cb-item"><input type="checkbox"><span>Portfolio or Gallery</span></label>
        <label class="cb-item"><input type="checkbox"><span>Testimonials</span></label>
        <label class="cb-item"><input type="checkbox"><span>Booking Page</span></label>
        <label class="cb-item"><input type="checkbox"><span>Members Login Area</span></label>
        <label class="cb-item"><input type="checkbox"><span>Blog or News</span></label>
        <label class="cb-item"><input type="checkbox"><span>Custom Landing Page</span></label>
        <label class="cb-item"><input type="checkbox"><span>Other</span></label>
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Approximately how many pages total?</label>
        <input type="text" placeholder="e.g. 5 pages, 8 pages">
      </div>
      <div class="field-group">
        <label>Do you have written content ready?</label>
        <input type="text" placeholder="e.g. Yes all ready / Partially / No, need help writing it">
      </div>
    </div>

    <div class="field-group">
      <label>Describe any content you already have prepared:</label>
      <textarea class="sm" placeholder="e.g. I have an About page written, 10 product photos, and a brand video. I need help writing service descriptions and the homepage headline."></textarea>
    </div>

    <!-- SECTION 5: DESIGN -->
    <div class="section-header">
      <div class="section-badge">5</div>
      <h2>Design and Style</h2>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">How would you describe the look and feel you want? <span style="font-weight:400;color:#718096;">(Select all that apply)</span></div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Clean and minimal</span></label>
        <label class="cb-item"><input type="checkbox"><span>Bold and high energy</span></label>
        <label class="cb-item"><input type="checkbox"><span>Luxury and premium</span></label>
        <label class="cb-item"><input type="checkbox"><span>Corporate and professional</span></label>
        <label class="cb-item"><input type="checkbox"><span>Modern and creative</span></label>
        <label class="cb-item"><input type="checkbox"><span>Elegant and refined</span></label>
        <label class="cb-item"><input type="checkbox"><span>Bright and colorful</span></label>
        <label class="cb-item"><input type="checkbox"><span>Dark and moody</span></label>
        <label class="cb-item"><input type="checkbox"><span>Warm and approachable</span></label>
      </div>
    </div>

    <div class="row">
      <div class="field-group">
        <label>Brand Colors <span class="hint">List hex codes or describe them</span></label>
        <input type="text" placeholder="e.g. Deep navy #1A1A2E, Orange #F6973F, White">
      </div>
      <div class="field-group">
        <label>Colors to AVOID</label>
        <input type="text" placeholder="e.g. Bright red, yellow, pink">
      </div>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">Preferred background style:</div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Light or white background</span></label>
        <label class="cb-item"><input type="checkbox"><span>Dark background</span></label>
        <label class="cb-item"><input type="checkbox"><span>No preference, trust your judgment</span></label>
      </div>
    </div>

    <div class="field-group">
      <label>Any specific fonts or typography you like? <span class="hint">Leave blank if unsure, we will recommend.</span></label>
      <input type="text" placeholder="e.g. Clean modern fonts similar to Apple or Airbnb. Nothing too decorative or script-style.">
    </div>

    <!-- SECTION 6: INSPIRATION -->
    <div class="section-header">
      <div class="section-badge">6</div>
      <h2>Website Inspiration</h2>
    </div>

    <div class="info-banner">
      List 2 to 3 websites you admire. Be specific about what you like: layout, colors, navigation, images, overall feel, or how they present their offer.
    </div>

    <div class="inspiration-block">
      <div class="insp-title">Website 1</div>
      <div class="row">
        <div class="field-group">
          <label>Website URL</label>
          <input type="text" placeholder="e.g. www.example.com">
        </div>
      </div>
      <div class="field-group">
        <label>What specifically do you like about this website?</label>
        <textarea class="sm" placeholder="e.g. I love the bold hero section, the clean navigation, dark background with gold accents, and how easy it is to find the contact button."></textarea>
      </div>
    </div>

    <div class="inspiration-block">
      <div class="insp-title">Website 2</div>
      <div class="row">
        <div class="field-group">
          <label>Website URL</label>
          <input type="text" placeholder="e.g. www.example.com">
        </div>
      </div>
      <div class="field-group">
        <label>What specifically do you like about this website?</label>
        <textarea class="sm" placeholder="e.g. I like the way they display their services with icons, the testimonials section feels very credible, and the mobile version is excellent."></textarea>
      </div>
    </div>

    <div class="inspiration-block">
      <div class="insp-title">Website 3 <span style="font-weight:400;color:#718096;font-size:11px;">(optional)</span></div>
      <div class="row">
        <div class="field-group">
          <label>Website URL</label>
          <input type="text" placeholder="e.g. www.example.com">
        </div>
      </div>
      <div class="field-group">
        <label>What specifically do you like about this website?</label>
        <textarea class="sm" placeholder="e.g. Their pricing page is very clear and the photography style matches exactly the premium feel I want for my brand."></textarea>
      </div>
    </div>

    <!-- SECTION 7: FEATURES -->
    <div class="section-header">
      <div class="section-badge">7</div>
      <h2>Features and Functionality</h2>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">Which features do you need on your website? <span style="font-weight:400;color:#718096;">(Select all that apply)</span></div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Contact form</span></label>
        <label class="cb-item"><input type="checkbox"><span>Booking or scheduling</span></label>
        <label class="cb-item"><input type="checkbox"><span>Online payments</span></label>
        <label class="cb-item"><input type="checkbox"><span>E-commerce store</span></label>
        <label class="cb-item"><input type="checkbox"><span>Live chat</span></label>
        <label class="cb-item"><input type="checkbox"><span>Email list signup</span></label>
        <label class="cb-item"><input type="checkbox"><span>CRM integration</span></label>
        <label class="cb-item"><input type="checkbox"><span>WhatsApp chat button</span></label>
        <label class="cb-item"><input type="checkbox"><span>Members login area</span></label>
        <label class="cb-item"><input type="checkbox"><span>Blog or news section</span></label>
        <label class="cb-item"><input type="checkbox"><span>Video embedding</span></label>
        <label class="cb-item"><input type="checkbox"><span>Social media feeds</span></label>
      </div>
    </div>

    <div class="field-group">
      <label>Any other tools or integrations your site must connect to?</label>
      <textarea class="sm" placeholder="e.g. We use Calendly for bookings, Stripe for payments, Mailchimp for email marketing, and HubSpot CRM for client management."></textarea>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">Do you need ongoing website maintenance after launch?</div>
      <div class="cb-grid cols-2">
        <label class="cb-item"><input type="checkbox"><span>Yes, monthly maintenance plan</span></label>
        <label class="cb-item"><input type="checkbox"><span>Yes, on an as-needed basis</span></label>
        <label class="cb-item"><input type="checkbox"><span>No, I will manage it myself</span></label>
        <label class="cb-item"><input type="checkbox"><span>Not sure yet</span></label>
      </div>
    </div>

    <!-- SECTION 8: CONTENT & MEDIA -->
    <div class="section-header">
      <div class="section-badge">8</div>
      <h2>Content and Media</h2>
    </div>

    <div class="checkbox-section">
      <div class="cb-question">Do you have professional photos of your business, team, or products?</div>
      <div class="cb-grid cols-3">
        <label class="cb-item"><input type="checkbox"><span>Yes, photos are ready</span></label>
        <label class="cb-item"><input type="checkbox"><span>Some photos but need more</span></label>
        <label class="cb-item"><input type="checkbox"><span>No photos, need help sourcing or shooting</span></label>
